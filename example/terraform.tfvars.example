# Copy this file to terraform.tfvars and fill in the values.
# Never commit terraform.tfvars to version control.
#
# If you hit intermittent "tls: bad record MAC" errors during apply, run:
#   GODEBUG=http2client=0 tofu apply
# This disables Go's HTTP/2 client and forces HTTP/1.1 for OCI API calls.
# The .envrc file in this directory sets it automatically if you use direnv.

# OCI Authentication
# user_ocid, fingerprint, private_key_path are optional when ~/.oci/config exists
# (run `oci setup config` to create it). Set them explicitly for CI or when no config file is present.
tenancy_ocid     = "ocid1.tenancy.oc1..example"
compartment_ocid = "ocid1.compartment.oc1..example"
# user_ocid        = "ocid1.user.oc1..example"
# fingerprint      = "xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx"
# private_key_path = "~/.oci/oci_api_key.pem"

# Region & placement  (must be your home region for Always Free)
region              = "eu-frankfurt-1"
availability_domain = "Uocm:EU-FRANKFURT-1-AD-1"

# Cluster
cluster_name  = "my-k3s"
environment   = "staging"

# OS images — optional; latest Ubuntu 24.04 Minimal is auto-detected from the tenancy.
# Override if you need a pinned or custom image OCID.
# Find OCIDs at: https://docs.oracle.com/en-us/iaas/images/
# os_image_id = "ocid1.image.oc1..example"   # aarch64 (A1.Flex nodes)

# Your workstation IP — restricts OCI Bastion Service session creation (enable_bastion=true),
# kubeapi access (expose_kubeapi=true), and direct SSH access (expose_ssh=true).
my_public_ip_cidr = "1.2.3.4/32"

# cert-manager — must be a real email for Let's Encrypt
certmanager_email_address = "you@example.com"

# SSH public key — pass content directly (avoids ~/.ssh path issues in CI)
# public_key = "ssh-ed25519 AAAA..."
# public_key_path = "~/.ssh/id_ed25519.pub"   # fallback when public_key is null

# Append all SSH keys published on a GitHub profile to every node's authorized_keys
# github_ssh_keys_username = "mbologna"

# ── Topology (Always Free: 4 OCPUs / 24 GB total across all A1.Flex nodes) ───
# Default: 3 HA control-plane nodes (instance pool) + 1 standalone worker = 4 × (1 OCPU / 6 GB)
# k3s_standalone_worker=true uses a direct oci_core_instance for the worker because
# OCI instance pools can fail for A1.Flex on Always Free tenancies (capacity errors).
k3s_server_pool_size  = 3
k3s_worker_pool_size  = 0   # Keep at 0; pool is reserved for future non-free scaling
k3s_standalone_worker = true

# compute_shape        = "VM.Standard.A1.Flex"  # Do not change — only A1.Flex is Always Free
# server_ocpus         = 1                       # OCPUs per server node  (total: server_ocpus × pool_size + worker_ocpus ≤ 4)
# server_memory_in_gbs = 6                       # RAM per server node    (total: must be ≤ 24 GB)
# worker_ocpus         = 1                       # OCPUs for standalone worker
# worker_memory_in_gbs = 6                       # RAM for standalone worker
# boot_volume_size_in_gbs = 50                   # Must be exactly 50 — 4×50 GB = 200 GB Always Free limit

# ── k3s ───────────────────────────────────────────────────────────────────────
# k3s_version = "latest"   # Pin to a specific release, e.g. "v1.32.4+k3s1"

# ── Optional features ─────────────────────────────────────────────────────────
# expose_kubeapi = false             # Expose kubeapi via public NLB (restricted to my_public_ip_cidr)
# expose_ssh     = false             # Expose SSH via public NLB (restricted to my_public_ip_cidr); see ssh_command output
#                                    # When true, set enable_bastion = false — OCI Bastion becomes redundant

# ── Always Free add-ons (enabled by default) ──────────────────────────────────
# enable_bastion              = true   # OCI Bastion Service — default access method when expose_ssh=false
#                                      # Set to false if expose_ssh=true (avoids lingering-VNIC delay on destroy)
# enable_vault                = true   # Store k3s_token/longhorn/grafana passwords in OCI Vault (software keys, free)
# enable_backup               = true   # Weekly boot volume backups, 1-week retention (max 4/5 free backups)
# enable_object_storage_state = true   # Versioned Object Storage bucket for Terraform state (S3-compatible)
# enable_longhorn_backup      = true   # Dedicated Object Storage bucket for Longhorn PVC backups (see longhorn_backup_setup output)

# ── Opt-in features (disabled by default) ─────────────────────────────────────
# enable_notifications = false          # OCI Notifications topic wired to Alertmanager webhook (1M HTTPS/month free)
# alertmanager_email   = "you@example.com"  # Optional email subscription for the Notifications topic
# enable_mysql         = false          # Always Free MySQL HeatWave DB system (MySQL.Free, 50 GB, private subnet)
# mysql_admin_username = "admin"        # MySQL admin username (password auto-generated)
# mysql_shape          = "MySQL.Free"   # Do not change — MySQL.Free is the Always Free shape

# ── Hostnames (set to create Gateway API HTTPRoutes + cert-manager TLS certs) ──
# longhorn_hostname    = "longhorn.example.com"
# longhorn_ui_username = "admin"          # BasicAuth username for the Longhorn UI
# grafana_hostname     = "grafana.example.com"

# ── GitOps ────────────────────────────────────────────────────────────────────
# Set to your fork URL so ArgoCD pulls from the right repository:
# gitops_repo_url = "https://github.com/your-org/k3s-oci.git"

# ── External DNS (Cloudflare) ─────────────────────────────────────────────────
# Automatically creates/updates DNS records for Ingress/Service resources.
# enable_external_dns    = false
# cloudflare_api_token   = "your-cloudflare-api-token"   # needs Zone:DNS:Edit
# cloudflare_zone_id     = "your-cloudflare-zone-id"
# external_dns_domain_filter = "example.com"

# ── External Secrets Operator (OCI Vault) ─────────────────────────────────────
# Sync OCI Vault secrets into Kubernetes Secrets via ExternalSecret CRs.
# Requires enable_vault = true.
# enable_external_secrets = false

# ── DNS-01 ACME challenge (Cloudflare) ────────────────────────────────────────
# Use Cloudflare DNS-01 solver instead of HTTP-01 for cert-manager.
# Enables wildcard certs (*.example.com); requires enable_external_dns = true.
# enable_dns01_challenge = false

# ── kured maintenance window ──────────────────────────────────────────────────
# kured is managed by ArgoCD. Edit gitops/apps/kured.yaml to change the
# maintenance window (startTime, endTime, rebootDays) or chart version.

# ── DockerHub credentials (avoids anonymous pull rate limits) ─────────────────
# dockerhub_username = "your-dockerhub-username"
# dockerhub_password = "your-dockerhub-pat"   # Personal Access Token (read-only is sufficient)

# ── Chart versions (managed by Renovate — only override to pin) ───────────────
# gateway_api_version            = "v1.5.1"
# certmanager_chart_version      = "v1.20.2"
# argocd_chart_version           = "9.5.9"
# external_secrets_chart_version = "2.4.1"

# ── Advanced networking (change only if defaults conflict with your VCN) ───────
# oci_core_vcn_cidr                 = "10.0.0.0/16"
# public_subnet_cidr                = "10.0.0.0/24"
# private_subnet_cidr               = "10.0.1.0/24"
# oci_core_vcn_dns_label            = "k3svcn"
# public_subnet_dns_label           = "k3spublic"
# private_subnet_dns_label          = "k3sprivate"
# kube_api_port                     = 6443
# http_lb_port                      = 80
# https_lb_port                     = 443
# ingress_controller_http_nodeport  = 30080
# ingress_controller_https_nodeport = 30443
# k3s_subnet                        = "default_route_table"
# fault_domains                     = ["FAULT-DOMAIN-1", "FAULT-DOMAIN-2", "FAULT-DOMAIN-3"]

# ── Advanced IAM (change only if names conflict with existing OCI resources) ───
# oci_identity_dynamic_group_name = "k3s-cluster-dynamic-group"
# oci_identity_policy_name        = "k3s-cluster-policy"
# unique_tag_key                  = "k3s-provisioner"
# unique_tag_value                = "https://github.com/mbologna/k3s-oci"
