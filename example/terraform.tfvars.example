# Copy this file to terraform.tfvars and fill in the values.
# Never commit terraform.tfvars to version control.

# OCI Authentication
tenancy_ocid     = "ocid1.tenancy.oc1..example"
user_ocid        = "ocid1.user.oc1..example"
fingerprint      = "xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx"
private_key_path = "~/.oci/oci_api_key.pem"

# Region & placement  (must be your home region for Always Free)
region              = "eu-frankfurt-1"
availability_domain = "Uocm:EU-FRANKFURT-1-AD-1"

# Cluster
cluster_name  = "my-k3s"
environment   = "staging"

# Ubuntu 24.04 LTS (Noble) Minimal for aarch64 — find current OCIDs at:
# https://docs.oracle.com/en-us/iaas/images/
os_image_id = "ocid1.image.oc1..example"

# Your workstation IP (restricts SSH and optional kubeapi exposure)
my_public_ip_cidr = "1.2.3.4/32"

# cert-manager — must be a real email for Let's Encrypt
certmanager_email_address = "you@example.com"

# SSH public key — pass content directly (avoids ~/.ssh path issues in CI)
# public_key = "ssh-ed25519 AAAA..."
# public_key_path = "~/.ssh/id_ed25519.pub"   # fallback when public_key is null

# ── Topology (Always Free: 4 OCPUs / 24 GB total across all A1.Flex nodes) ───
# Default: 3 HA control-plane nodes + 1 standalone extra worker = 4 × (1 OCPU / 6 GB)
k3s_server_pool_size  = 3
k3s_worker_pool_size  = 0
k3s_extra_worker_node = true

# ── Optional ──────────────────────────────────────────────────────────────────
# enable_bastion   = true                      # Adds a free E2.1.Micro bastion
# expose_kubeapi   = false                     # Expose kubeapi via public NLB (restricted to my_public_ip_cidr)
# argocd_hostname  = "argocd.example.com"      # Creates Traefik IngressRoute + cert-manager certificate for ArgoCD
