{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>mbologna/.github//renovate-config.json"
  ],
  "packageRules": [
    {
      "description": "Group all Terraform provider updates into one PR; require manual review",
      "matchManagers": [
        "terraform"
      ],
      "matchDepTypes": [
        "provider"
      ],
      "groupName": "terraform providers",
      "automerge": false
    },
    {
      "description": "k3s patch updates: bypass the 7-day age gate \u2014 k3s patches are stable fast-follows. 1 minute (not 0 days) ensures Renovate posts a stability check; 0 days normalises to null internally and blocks automerge on repos without CI.",
      "matchPackageNames": [
        "k3s-io/k3s"
      ],
      "matchUpdateTypes": [
        "patch"
      ],
      "minimumReleaseAge": "1 minute"
    }
  ],
  "customManagers": [
    {
      "description": "Update versions declared with inline renovate comments in vars.tf",
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)vars\\.tf$/"
      ],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>[^\\s]+)\\s+depName=(?<depName>[^\\s]+)(\\s+registryUrl=(?<registryUrl>[^\\s]+))?\\s*\\n\\s*default\\s*=\\s*\"(?<currentValue>[^\"]+)\""
      ]
    },
    {
      "description": "Update Helm chart versions declared with inline renovate comments in gitops YAML files",
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)gitops/.*\\.yaml$/"
      ],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>[^\\s]+)\\s+depName=(?<depName>[^\\s]+)(\\s+registryUrl=(?<registryUrl>[^\\s]+))?\\s*\\n\\s*targetRevision:\\s*\"(?<currentValue>[^\"]+)\""
      ]
    },
    {
      "description": "Update system-upgrade-controller version in kustomization.yaml remote resource URLs",
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)gitops/system-upgrade/kustomization\\.yaml$/"
      ],
      "matchStrings": [
        "system-upgrade-controller/releases/download/(?<currentValue>[^/]+)/"
      ],
      "depNameTemplate": "rancher/system-upgrade-controller",
      "datasourceTemplate": "github-releases"
    },
    {
      "description": "Update external-dns chart version hardcoded in create_external_dns_app() shell function. Must be kept in sync with gitops/optional/external-dns.yaml targetRevision.",
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)files/lib/k3s-argocd\\.sh$/"
      ],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>[^\\s]+)\\s+depName=(?<depName>[^\\s]+)(\\s+registryUrl=(?<registryUrl>[^\\s]+))?\\s*\\n\\s*local chart_version=\"(?<currentValue>[^\"]+)\""
      ]
    }
  ]
}
