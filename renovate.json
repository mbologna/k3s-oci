{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard"
  ],
  "labels": ["dependencies"],
  "reviewers": ["mbologna"],
  "terraform": {
    "enabled": true
  },
  "github-actions": {
    "enabled": true
  },
  "packageRules": [
    {
      "description": "Group all Terraform provider updates into one PR",
      "matchManagers": ["terraform"],
      "matchDepTypes": ["provider"],
      "groupName": "terraform providers",
      "automerge": false
    },
    {
      "description": "Pin GitHub Actions to digest SHAs for supply-chain security",
      "matchManagers": ["github-actions"],
      "pinDigests": true,
      "automerge": false
    },
    {
      "description": "Auto-merge patch-level k3s updates",
      "matchPackageNames": ["k3s-io/k3s"],
      "matchUpdateTypes": ["patch"],
      "automerge": true
    }
  ],
  "customManagers": [
    {
      "description": "Update versions declared with inline renovate comments in vars.tf",
      "customType": "regex",
      "fileMatch": ["(^|/)vars\\.tf$"],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>[^\\s]+)\\s+depName=(?<depName>[^\\s]+)(\\s+registryUrl=(?<registryUrl>[^\\s]+))?\\s*\\n\\s*default\\s*=\\s*\"(?<currentValue>[^\"]+)\""
      ]
    },
    {
      "description": "Update Helm chart versions declared with inline renovate comments in gitops YAML files",
      "customType": "regex",
      "fileMatch": ["(^|/)gitops/.*\\.yaml$"],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>[^\\s]+)\\s+depName=(?<depName>[^\\s]+)(\\s+registryUrl=(?<registryUrl>[^\\s]+))?\\s*\\n\\s*targetRevision:\\s*\"(?<currentValue>[^\"]+)\""
      ]
    },
    {
      "description": "Update system-upgrade-controller version in kustomization.yaml remote resource URLs",
      "customType": "regex",
      "fileMatch": ["(^|/)gitops/system-upgrade/kustomization\\.yaml$"],
      "matchStrings": [
        "system-upgrade-controller/releases/download/(?<currentValue>[^/]+)/"
      ],
      "depNameTemplate": "rancher/system-upgrade-controller",
      "datasourceTemplate": "github-releases"
    }
  ]
}
