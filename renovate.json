{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "github>mbologna/renovate-config"
  ],
  "terraform": {
    "enabled": true
  },
  "github-actions": {
    "enabled": true
  },
  "packageRules": [
    {
      "description": "Group all Terraform provider updates into one PR; require manual review",
      "matchManagers": [
        "terraform"
      ],
      "matchDepTypes": [
        "provider"
      ],
      "groupName": "terraform providers",
      "automerge": false
    },
    {
      "description": "GitHub Actions: no auto-merge (pinDigests already set globally)",
      "matchManagers": [
        "github-actions"
      ],
      "automerge": false
    },
    {
      "description": "k3s patch updates: bypass the 7-day age gate — k3s patches are stable fast-follows",
      "matchPackageNames": [
        "k3s-io/k3s"
      ],
      "matchUpdateTypes": [
        "patch"
      ],
      "minimumReleaseAge": "0 days",
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash"
    }
  ],
  "customManagers": [
    {
      "description": "Update versions declared with inline renovate comments in vars.tf",
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)vars\\.tf$/"
      ],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>[^\\s]+)\\s+depName=(?<depName>[^\\s]+)(\\s+registryUrl=(?<registryUrl>[^\\s]+))?\\s*\\n\\s*default\\s*=\\s*\"(?<currentValue>[^\"]+)\""
      ]
    },
    {
      "description": "Update Helm chart versions declared with inline renovate comments in gitops YAML files",
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)gitops/.*\\.yaml$/"
      ],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>[^\\s]+)\\s+depName=(?<depName>[^\\s]+)(\\s+registryUrl=(?<registryUrl>[^\\s]+))?\\s*\\n\\s*targetRevision:\\s*\"(?<currentValue>[^\"]+)\""
      ]
    },
    {
      "description": "Update system-upgrade-controller version in kustomization.yaml remote resource URLs",
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)gitops/system-upgrade/kustomization\\.yaml$/"
      ],
      "matchStrings": [
        "system-upgrade-controller/releases/download/(?<currentValue>[^/]+)/"
      ],
      "depNameTemplate": "rancher/system-upgrade-controller",
      "datasourceTemplate": "github-releases"
    }
  ]
}
